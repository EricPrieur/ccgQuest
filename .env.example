# PostHog analytics. Copy this file to `.env` and fill in your project key.
# Without VITE_POSTHOG_KEY set, analytics is a no-op (good for local dev).
#
# Get the key from PostHog → Project Settings → Project API Key.
# It is a write-only public key (safe to ship in a static client bundle).

VITE_POSTHOG_KEY=
# Use https://eu.i.posthog.com for the EU cloud, https://us.i.posthog.com for the US cloud.
VITE_POSTHOG_HOST=https://us.i.posthog.com
